; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Box3D Godot Samples"
config/description="Interactive samples for the Box3D physics engine in Godot."
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

common/physics_interpolation=true

[rendering]

anti_aliasing/quality/msaa_3d=2
; Mobile overrides (the ".mobile" feature tag only applies on phones/tablets;
; desktop reads the plain keys above/below and is unaffected). The desktop
; values are heavy for a mobile GPU -- an 8192 shadow map alone is a large
; slice of frame time on a phone -- and were the main source of low FPS on
; device. Same scenes, same cube counts; only shadow resolution and MSAA drop.
anti_aliasing/quality/msaa_3d.mobile=0
lights_and_shadows/directional_shadow/size=8192
lights_and_shadows/directional_shadow/size.mobile=2048
lights_and_shadows/directional_shadow/soft_shadow_filter_quality.mobile=1
limits/global_shader_variables/buffer_size=262144
; Required by Godot's Android export gate. The demo ships no textures (all
; meshes are procedural), so this compresses nothing and does not affect the
; desktop demo -- it only satisfies the export check. See ANDROID_BUILD.md.
textures/vram_compression/import_etc2_astc=true
